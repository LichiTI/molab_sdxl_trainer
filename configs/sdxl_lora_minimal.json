{
  "schema_id": "sdxl-lora",
  "training_type": "lora",
  "model_type": "sdxl",

  "pretrained_model_name_or_path": "work/models/sd_xl_base_1.0.safetensors",
  "base_model_path": "work/models/sd_xl_base_1.0.safetensors",
  "vae_path": "",
  "train_data_dir": "work/datasets/my_lora",
  "output_dir": "work/outputs",
  "logging_dir": "work/logs",
  "output_name": "my_sdxl_lora",

  "network_module": "networks.lora",
  "network_dim": 16,
  "network_alpha": 8,
  "network_dropout": 0.0,
  "network_train_unet_only": false,
  "network_train_text_encoder_only": false,

  "resolution": "1024,1024",
  "enable_bucket": true,
  "min_bucket_reso": 512,
  "max_bucket_reso": 1536,
  "bucket_reso_steps": 64,
  "bucket_no_upscale": false,
  "caption_extension": ".txt",
  "shuffle_caption": true,
  "keep_tokens": 1,
  "max_token_length": 225,

  "train_batch_size": 1,
  "gradient_accumulation_steps": 1,
  "max_train_epochs": 10,
  "max_train_steps": 0,
  "learning_rate": 0.0001,
  "unet_lr": 0.0001,
  "text_encoder_lr": 0.00001,
  "optimizer_type": "AdamW8bit",
  "optimizer_args": "",
  "lr_scheduler": "cosine",
  "lr_warmup_steps": 0,
  "lr_scheduler_num_cycles": 1,
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,

  "mixed_precision": "bf16",
  "save_precision": "bf16",
  "gradient_checkpointing": true,
  "cache_latents": true,
  "cache_latents_to_disk": true,
  "cache_text_encoder_outputs": false,
  "cache_text_encoder_outputs_to_disk": false,
  "attention_backend": "sdpa",
  "sdpa": true,
  "xformers": false,
  "torch_compile": false,

  "save_model_as": "safetensors",
  "save_every_n_epochs": 1,
  "save_every_n_steps": 0,
  "checkpoint_keep_last": 3,
  "save_state": false,
  "save_state_on_train_end": false,
  "seed": 42,

  "sample_every": false,
  "sample_every_n_epochs": 0,
  "sample_prompts": "",

  "low_vram_profile": "off",
  "sdxl_low_vram_optimization": false,
  "execution_core": "standard"
}
